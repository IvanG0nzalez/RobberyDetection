# ARCHIVOS PESADOS DEL PROYECTO

# DATA - Videos originales
# Ignorar todos los videos
data/raw/dataset_videos_original/**/*.mp4
data/raw/dataset_videos_recortados/**/*.mp4
data/raw/dataset_videos_raw/**/*.mp4

# EXCEPCIONES: Incluir solo archivos de muestra específicos
# 1 video Normal y 1 video Robbery como ejemplo
!data/raw/dataset_videos_original/Normal/Normal_Videos001_x264.mp4
!data/raw/dataset_videos_original/Robbery/Robbery001_x264.mp4
!data/raw/dataset_videos_recortados/Normal/Normal_Videos001_x264.mp4
!data/raw/dataset_videos_recortados/Robbery/Robbery001_x264.mp4

# DATA - Clips intermedios
# Ignorar todo el contenido interno de las subcarpetas de generación
data/interim/*/*

# Excepción 1: Conservar el archivo generation_metadata.json
!data/interim/*/generation_metadata.json

# Excepción 2: Conservar los directorios base de las clases
!data/interim/*/Normal/
!data/interim/*/Robbery/

# Excepción 3: Vaciar el contenido dentro de Normal y Robbery
data/interim/*/Normal/*
data/interim/*/Robbery/*

# Excepción 4: Permitir archivos .gitkeep para que git trackee los directorios vacíos
!data/interim/*/Normal/.gitkeep
!data/interim/*/Robbery/.gitkeep

# DATA - Archivos procesados (Features numpy)
# Ignorar el contenido completo de directorios procesados de features
data/processed/*/*/*

# Excepción 1: Conservar el contenedor con los directorios base de clases
!data/processed/*/Normal/
!data/processed/*/Robbery/

# Excepción 2: Permitir los archivos .gitkeep para mantener la estructura visible
!data/processed/*/Normal/.gitkeep
!data/processed/*/Robbery/.gitkeep

# RESULTS - Resultados finales
# Mantener código de inferencia pero ignorar modelos pesados
results/*.pth
results/*.pt

# NUMPY ARRAYS
# Los archivos .npy de features pueden ser pesados
**/*.npy


# MODELO COMPLETO DE INFERENCIA
results/inference/hybrid_model_complete.pth